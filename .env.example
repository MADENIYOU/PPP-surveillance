# Copier en .env (jamais committé) et remplacer les valeurs avant "docker compose up".
# Référence : 06_gestion/ROADMAP_PHASE_3.md (I3.6), 04_implementation/influxdb/02_influxdb_config.flux

# --- PostgreSQL ---
POSTGRES_USER=dakar_admin
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_DB=dakar_pollution

# --- InfluxDB ---
INFLUXDB_USER=dakar_admin
INFLUXDB_PASSWORD=changeme_dev_only
INFLUXDB_ORG=dakar_pollution
# Token admin initial (créé au premier démarrage). Générer une valeur aléatoire forte
# en local : openssl rand -hex 32
INFLUXDB_ADMIN_TOKEN=changeme_generate_a_random_token
